# Base URLs
BASE_URL=https://tmdb-discover.surge.sh
TMDB_API_BASE=https://api.themoviedb.org/3
TMDB_API_KEY=your_tmdb_api_key_here

# Browser settings
BROWSER=chrome
HEADLESS=true
IMPLICIT_WAIT=10000
PAGE_LOAD_TIMEOUT=30000

# Test settings
RETRY_ATTEMPTS=2
SCREENSHOT_ON_FAILURE=true
LOG_LEVEL=info
